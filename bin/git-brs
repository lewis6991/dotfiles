#! /usr/bin/env python3
"""
This module provides utilities for displaying information about Git branches,
pull requests (PRs), and Gerrit code reviews in a formatted and colorized manner.
It integrates with GitHub CLI (`gh`) and Gerrit via SSH to fetch metadata about
branches, PRs, and code review approvals, and prints them with enhanced formatting
for terminal output, including hyperlinks and color codes.
"""

from __future__ import annotations

from concurrent.futures import Future
from concurrent.futures import ThreadPoolExecutor
from dataclasses import dataclass
from dataclasses import field
from functools import cached_property
from functools import lru_cache
from os.path import relpath
from pathlib import Path
import re
import shlex
import json
import argparse
import sys

import subprocess

from typing import ClassVar
from typing import TypedDict
from typing import cast
from enum import StrEnum

_THIS = '\uf111'


class _Ansi(StrEnum):
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    MAGENTA = '\033[95m'
    RED = '\033[91m'
    END = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'
    GREY = '\033[90m'

    # hyperlinks
    OSC8_1 = '\033]8;;'
    OSC8_2 = '\033\\'
    OSC8_3 = '\033]8;;\033\\'


_MERGED_STYLE = f'{_Ansi.BOLD}{_Ansi.CYAN}'


def _run(cmd: str | list[str]) -> str:
    if isinstance(cmd, str):
        cmd = shlex.split(cmd)
    return subprocess.run(cmd, capture_output=True, text=True, check=True).stdout.rstrip('\n')


def _link(text: str, url: str) -> str:
    return f'{_Ansi.UNDERLINE}{_Ansi.OSC8_1}{url}{_Ansi.OSC8_2}{text}{_Ansi.OSC8_3}{_Ansi.END}'


@lru_cache(maxsize=None)
def _resolve_ref_oid(ref: str) -> str | None:
    if not ref:
        return None
    result = subprocess.run(
        ['git', 'rev-parse', '--verify', ref],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def _branch_oids(branch_name: str, upstream: str) -> set[str]:
    refs = [f'refs/heads/{branch_name}']
    if upstream:
        refs.append(upstream)
    return {oid for ref in refs if (oid := _resolve_ref_oid(ref))}


@dataclass
class _Gerrit:
    _host: str
    _port: ClassVar[int] = 29418
    _query_cache: dict[str, list[_Gerrit.QueryResult]] = field(default_factory=dict, init=False)
    _change_cache: dict[str, list[_Gerrit.QueryResult]] = field(default_factory=dict, init=False)
    _change_id_re: ClassVar[re.Pattern[str]] = re.compile(r'^I[a-f0-9]{40}$', re.IGNORECASE)
    _batch_size: ClassVar[int] = 16

    class User(TypedDict):
        name: str
        email: str
        username: str

    class Approval(TypedDict):
        type: str
        value: str
        by: _Gerrit.User

    class PatchSet(TypedDict):
        number: int
        revision: str
        parent: list[str]
        ref: str
        uploader: _Gerrit.User
        author: _Gerrit.User
        createdOn: int
        kind: str
        sizeInsertions: int
        sizeDeletions: int

    class CurrentPatchSet(PatchSet):
        approvals: list[_Gerrit.Approval]

    class QueryResult(TypedDict):
        id: str
        url: str
        currentPatchSet: _Gerrit.CurrentPatchSet
        patchSets: list[_Gerrit.PatchSet]
        number: int
        project: str
        subject: str
        status: str

    @staticmethod
    def get_change_id(commit_body: list[str]) -> str | None:
        for line in commit_body:
            if m := re.search('Change-Id: (.*)', line):
                return m.group(1)
        return None

    @staticmethod
    def _origin_host() -> str | None:
        try:
            url = _run('git config --get remote.origin.url').strip()
        except subprocess.CalledProcessError:
            return None
        if match := re.match(r'(?:ssh://)?(?:[^@]+@)?([^:/]+)', url):
            host = match.group(1)
        else:
            host = url.split(':')[0]
        if 'gerrit' not in host:
            return None
        return host

    @staticmethod
    def origin_base_url() -> str | None:
        if host := _Gerrit._origin_host():
            return f'https://{host}'
        return None

    @staticmethod
    def _fmt_label(label: str, approvals: list[_Gerrit.Approval]) -> str:
        label_abbr = _Gerrit._label_token(label)
        values = ', '.join(_Gerrit._approval_summary(approval) for approval in approvals)
        fail = any(int(approval['value']) < 0 for approval in approvals)
        if fail:
            return f'{_Ansi.RED}{label_abbr}[{values}{_Ansi.RED}]{_Ansi.END}'

        return f'{_Ansi.GREEN}{label_abbr}[{len(approvals)}]{_Ansi.END}'

    @staticmethod
    def _approval_name(approval: _Gerrit.Approval) -> str:
        username = approval['by'].get('username', '')
        if username:
            return username
        return approval['by']['name'].split()[0].lower()

    @staticmethod
    def _approval_summary(approval: _Gerrit.Approval) -> str:
        value = int(approval['value'])
        name = approval['by']['name']
        color = _Ansi.GREEN if value > 0 else _Ansi.RED
        summary = f'{value:+d}' if value > 0 else f'{value} ({name})'
        return f'{color}{summary}'

    @staticmethod
    def _label_token(label: str) -> str:
        return ''.join(part[0].lower() for part in label.split('-') if part)

    @staticmethod
    def _approval_token(label: str, approval: _Gerrit.Approval) -> str:
        value = int(approval['value'])
        token = f'{_Gerrit._label_token(label)}{value:+d}'
        if value < 0:
            token += f'({_Gerrit._approval_name(approval)})'
        color = _Ansi.GREEN if value > 0 else _Ansi.RED
        return f'{color}{token}{_Ansi.END}'

    def _line_for_result(self, result: _Gerrit.QueryResult, sha: str | None = None) -> list[str]:
        lines: list[str] = []
        currentps = result['currentPatchSet']['number']
        patchset = '?'
        if sha is not None:
            for ps in result['patchSets']:
                if ps['revision'] == sha:
                    patchset = ps['number']
                    break
        else:
            lines.append(f'{_Ansi.YELLOW}{result["project"]}:{_Ansi.END}')
            lines.append(f'      {_Ansi.BLUE}{result["subject"]}{_Ansi.END}')

        ln = _link(str(result['number']), result['url'])
        if sha is not None:
            line = f'      {_Ansi.CYAN}{_Ansi.BOLD}gr{_Ansi.END} {ln} '
        else:
            line = f'      └ {ln} '

        if sha is not None:
            color = _Ansi.GREEN if result['currentPatchSet']['revision'] == sha else _Ansi.RED
            line += f'{color}{patchset}/{currentps}{_Ansi.END}'
        else:
            line += f'{_Ansi.BLUE}ps {currentps}{_Ansi.END}'

        match result['status']:
            case 'NEW':
                pass
            case x:
                status_color = _MERGED_STYLE if x == 'MERGED' else _Ansi.BLUE
                sep = ' ' if sha is not None else ', '
                line += f'{sep}{status_color}{x.lower()}{_Ansi.END}'

        approvals_by_label: dict[str, list[_Gerrit.Approval]] = {}
        for approval in result['currentPatchSet'].get('approvals', []):
            approvals_by_label.setdefault(approval['type'], []).append(approval)

        if sha is not None:
            approval_tokens: list[str] = []
            for label in sorted(approvals_by_label):
                approvals = sorted(
                    approvals_by_label[label],
                    key=lambda approval: (
                        -int(approval['value']),
                        _Gerrit._approval_name(approval),
                    ),
                )
                positive_counts: dict[int, int] = {}
                negative_approvals: list[_Gerrit.Approval] = []
                for approval in approvals:
                    value = int(approval['value'])
                    if value > 0:
                        positive_counts[value] = positive_counts.get(value, 0) + 1
                    else:
                        negative_approvals.append(approval)
                for value in sorted(positive_counts, reverse=True):
                    count = positive_counts[value]
                    token = f'{_Gerrit._label_token(label)}{value:+d}'
                    if count > 1:
                        token += f'x{count}'
                    approval_tokens.append(f'{_Ansi.GREEN}{token}{_Ansi.END}')
                approval_tokens.extend(
                    _Gerrit._approval_token(label, approval) for approval in negative_approvals
                )
            if approval_tokens:
                line += ' ' + ' '.join(approval_tokens)
        else:
            labels = ', '.join(
                _Gerrit._fmt_label(label, approvals)
                for label, approvals in approvals_by_label.items()
            )
            if labels:
                line += f', {labels}'
        lines.append(line)
        return lines

    def _query(self, query: str) -> list[_Gerrit.QueryResult]:
        if query in self._query_cache:
            return self._query_cache[query]

        lines = _run(
            [
                'ssh',
                self._host,
                '-p',
                str(self._port),
                'gerrit',
                'query',
                query,
                '--current-patch-set',
                '--patch-sets',
                '--format=JSON',
            ]
        ).splitlines()
        results: list[_Gerrit.QueryResult] = []
        for line in lines:
            obj = cast(dict[str, object], json.loads(line))
            if obj.get('type') == 'stats':
                continue
            results.append(cast(_Gerrit.QueryResult, cast(object, obj)))
        self._query_cache[query] = results
        return results

    def _query_change_id(self, change_id: str) -> list[_Gerrit.QueryResult]:
        if change_id not in self._change_cache:
            self._change_cache[change_id] = self._query(f'change:{change_id}')
        return self._change_cache[change_id]

    def prefetch_change_ids(self, change_ids: list[str]) -> None:
        pending = [
            change_id
            for change_id in dict.fromkeys(change_ids)
            if change_id not in self._change_cache
        ]
        for i in range(0, len(pending), self._batch_size):
            chunk = pending[i : i + self._batch_size]
            query = ' OR '.join(f'change:{change_id}' for change_id in chunk)
            results_by_change_id: dict[str, list[_Gerrit.QueryResult]] = {
                change_id: [] for change_id in chunk
            }
            for result in self._query(query):
                if change_id := result.get('id'):
                    results_by_change_id.setdefault(change_id, []).append(result)
            for change_id in chunk:
                self._change_cache[change_id] = results_by_change_id.get(change_id, [])

    def info_lines(self, query: str, sha: str | None = None) -> list[str]:
        lines: list[str] = []
        results = (
            self._query_change_id(query)
            if self._change_id_re.fullmatch(query)
            else self._query(query)
        )
        for result in results:
            lines.extend(self._line_for_result(result, sha))
        return lines

    def info(self, query: str, sha: str | None = None):
        for line in self.info_lines(query, sha):
            print(line)

    @staticmethod
    def init() -> _Gerrit | None:
        host = _Gerrit._origin_host()
        if not host:
            return

        try:
            _ = _run(f'ssh {host} -p {_Gerrit._port} gerrit version')
            return _Gerrit(host)
        except subprocess.CalledProcessError:
            pass


class _Github:
    _branch_cache_key_prefix: ClassVar[str] = 'branch.'
    _branch_pr_number_key_suffix: ClassVar[str] = '.pr-number'
    _pr_cache_key_prefix: ClassVar[str] = 'git-brs.pr-'
    _pr_cache_fields: ClassVar[set[str]] = {'url', 'title', 'state', 'draft', 'base', 'oid'}
    _unresolved_comments_query: ClassVar[str] = """
query($owner: String!, $name: String!, $pr: Int!, $endCursor: String) {
  repository(owner: $owner, name: $name) {
    pullRequest(number: $pr) {
      reviewThreads(first: 100, after: $endCursor) {
        nodes {
          isResolved
          comments(first: 1) {
            totalCount
          }
        }
        pageInfo {
          hasNextPage
          endCursor
        }
      }
    }
  }
}
"""
    _repo_name_with_owner: str

    @dataclass
    class CheckSummary:
        token: str
        detail: str | None = None

    class Check(TypedDict):
        bucket: str
        link: str
        name: str
        state: str

    @dataclass
    class CachedPR:
        number: int | None = None
        url: str | None = None
        isDraft: bool = False
        state: str = 'OPEN'
        baseRefName: str | None = None
        headRefOid: str | None = None
        title: str = ''

    class PR(TypedDict):
        headRefName: str
        headRefOid: str | None
        url: str
        isDraft: bool
        state: str
        number: int
        baseRefName: str
        title: str
        updatedAt: str

    def __init__(self, repo_name_with_owner: str) -> None:
        self._repo_name_with_owner = repo_name_with_owner

    @cached_property
    def _repo_owner_name(self) -> tuple[str, str]:
        owner, _, name = self._repo_name_with_owner.partition('/')
        return owner, name

    @cached_property
    def _prs(self) -> list[_Github.PR]:
        try:
            r = _run(
                [
                    'gh',
                    'pr',
                    'list',
                    '--json=headRefName,headRefOid,url,isDraft,state,number,baseRefName,title,updatedAt',
                    '--state=all',
                    '--limit=300',
                    '--author=@me',
                ]
            )
            return cast(list[_Github.PR], json.loads(r))
        except subprocess.CalledProcessError as e:
            stderr = cast(str | None, e.stderr)
            if stderr:
                print(stderr)
            return []

    @cached_property
    def prs_by_head_ref(self) -> dict[str, list[_Github.PR]]:
        prs: dict[str, list[_Github.PR]] = {}
        for pr in self._prs:
            prs.setdefault(pr['headRefName'], []).append(pr)
        return prs

    @staticmethod
    def _remote_repo(url: str) -> str | None:
        stripped = url.rstrip('/')
        if stripped.endswith('.git'):
            stripped = stripped[:-4]
        if match := re.search(r'github\.com[:/]([^/]+/[^/]+)$', stripped):
            return match.group(1)
        return None

    @cached_property
    def base_remote(self) -> str | None:
        try:
            lines = _run(['git', 'remote', '-v']).splitlines()
        except subprocess.CalledProcessError:
            return None
        for line in lines:
            parts = line.split()
            if len(parts) < 2:
                continue
            remote, url = parts[:2]
            if self._remote_repo(url) == self._repo_name_with_owner:
                return remote
        return None

    @staticmethod
    def _pr_sort_key(pr: _Github.PR) -> tuple[int, str, int]:
        state_rank = {'OPEN': 2, 'MERGED': 1, 'CLOSED': 0}.get(pr['state'], 0)
        return (state_rank, pr['updatedAt'], pr['number'])

    def pr_for_branch(self, branch_name: str, upstream: str) -> _Github.PR | None:
        candidates = list(self.prs_by_head_ref.get(branch_name, []))
        if not candidates:
            return None

        branch_oids = _branch_oids(branch_name, upstream)
        if not branch_oids:
            return None
        candidates = [pr for pr in candidates if pr['headRefOid'] in branch_oids]
        if not candidates:
            return None

        return max(candidates, key=self._pr_sort_key)

    @staticmethod
    def _summarize_checks(checks: list[_Github.Check]) -> _Github.CheckSummary:
        if not checks:
            return _Github.CheckSummary(f'{_Ansi.GREY}-{_Ansi.END}')

        buckets = {check['bucket'] for check in checks}
        passed = sum(1 for check in checks if check['bucket'] == 'pass')
        failures: list[tuple[str, str | None]] = []
        for check in checks:
            if check['bucket'] not in {'fail', 'cancel'}:
                continue
            text = (
                f'{check["name"]} ({check["state"].lower()})'
                if check['bucket'] == 'cancel'
                else check['name']
            )
            failures.append((text, check.get('link')))
        if 'fail' in buckets or 'cancel' in buckets:
            if len(failures) == 1:
                failure_text, failure_url = failures[0]
                detail = f'{_Ansi.RED}{failure_text}{_Ansi.END}'
                if failure_url:
                    detail = _link(detail, failure_url)
                return _Github.CheckSummary(f'{_Ansi.RED}✗{_Ansi.END}', detail)
            detail = f'{_Ansi.RED}({passed}/{len(checks)}){_Ansi.END}'
            summary_url = failures[0][1] if failures else None
            if summary_url and (
                match := re.match(
                    r'^(https://github\.com/[^/]+/[^/]+/actions/runs/\d+)(?:/job/\d+)?$',
                    summary_url,
                )
            ):
                summary_url = match.group(1)
            if summary_url:
                detail = _link(detail, summary_url)
            return _Github.CheckSummary(
                f'{_Ansi.RED}✗{_Ansi.END}',
                detail,
            )
        if 'pending' in buckets:
            return _Github.CheckSummary(f'{_Ansi.YELLOW}…{_Ansi.END}')
        if 'pass' in buckets:
            return _Github.CheckSummary(f'{_Ansi.GREEN}✓{_Ansi.END}')
        if 'skipping' in buckets:
            return _Github.CheckSummary(f'{_Ansi.GREY}-{_Ansi.END}')
        return _Github.CheckSummary(f'{_Ansi.GREY}?{_Ansi.END}')

    def get_pr_checks(self, number: int) -> _Github.CheckSummary | None:
        result = subprocess.run(
            [
                'gh',
                'pr',
                'checks',
                str(number),
                '--json=bucket,link,name,state',
                '--required',
            ],
            capture_output=True,
            text=True,
            check=False,
        )
        stderr = cast(str | None, result.stderr)
        if result.returncode not in (0, 8):
            if stderr and re.search(r"^no (?:required )?checks reported on the '.*' branch$", stderr.strip()):
                return None
            if stderr:
                print(stderr)
            return None
        return self._summarize_checks(cast(list[_Github.Check], json.loads(result.stdout or '[]')))

    def get_pr_unresolved_comments(self, number: int) -> int | None:
        owner, name = self._repo_owner_name
        try:
            pages = cast(
                list[dict[str, object]],
                json.loads(
                    _run(
                        [
                            'gh',
                            'api',
                            'graphql',
                            '--paginate',
                            '--slurp',
                            '-F',
                            f'owner={owner}',
                            '-F',
                            f'name={name}',
                            '-F',
                            f'pr={number}',
                            '-f',
                            f'query={self._unresolved_comments_query}',
                        ]
                    )
                    or '[]'
                ),
            )
        except subprocess.CalledProcessError as e:
            stderr = cast(str | None, e.stderr)
            if stderr:
                print(stderr)
            return None

        unresolved_comments = 0
        for page in pages:
            data = cast(dict[str, object], page.get('data') or {})
            repository = cast(dict[str, object], data.get('repository') or {})
            pull_request = cast(dict[str, object], repository.get('pullRequest') or {})
            review_threads = cast(dict[str, object], pull_request.get('reviewThreads') or {})
            nodes = cast(list[dict[str, object]], review_threads.get('nodes') or [])
            for node in nodes:
                if node.get('isResolved'):
                    continue
                comments = cast(dict[str, object], node.get('comments') or {})
                total_count = comments.get('totalCount')
                if isinstance(total_count, int):
                    unresolved_comments += total_count
        return unresolved_comments

    @staticmethod
    def format_pr_line(
        number: int,
        url: str,
        is_draft: bool,
        state: str,
        title: str,
        unresolved_comments: int | None = None,
        checks_summary: _Github.CheckSummary | None = None,
    ) -> str:
        tokens: list[str] = []
        if is_draft:
            tokens.append(f'{_Ansi.BLUE}draft{_Ansi.END}')
        elif state == 'MERGED':
            tokens.append(f'{_MERGED_STYLE}merged{_Ansi.END}')
        elif state != 'OPEN':
            tokens.append(f'{_Ansi.RED}{state.lower()}{_Ansi.END}')
        info_tokens: list[str] = []
        if unresolved_comments:
            info_tokens.append(f'{_Ansi.YELLOW}comments:{unresolved_comments}{_Ansi.END}')
        checks_tokens: list[str] = []
        if checks_summary:
            checks_tokens.append(checks_summary.token)
            if checks_summary.detail:
                checks_tokens.append(checks_summary.detail)

        ln = _link(f'#{number}', url)
        line = f'  {_Ansi.CYAN}{_Ansi.BOLD}gh{_Ansi.END} {ln}'
        if tokens:
            line += f' {" ".join(tokens)}'
        if title:
            line += f'  {_Ansi.BLUE}{title}{_Ansi.END}'
        if info_tokens:
            line += f' {" ".join(info_tokens)}'
        if checks_tokens:
            line += f' {" ".join(checks_tokens)}'
        return line

    @staticmethod
    def init() -> _Github | None:
        try:
            r = _run('gh repo view --json=nameWithOwner')
            repo = cast(dict[str, str], json.loads(r))
            github = _Github(repo['nameWithOwner'])
            _ = github.prs_by_head_ref
            return github
        except subprocess.CalledProcessError:
            return None

    @classmethod
    def cached_prs(cls, local_branches: set[str]) -> dict[str, _Github.CachedPR]:
        if not local_branches:
            return {}
        result = subprocess.run(
            [
                'git',
                'config',
                '--local',
                '--get-regexp',
                rf'^{re.escape(cls._branch_cache_key_prefix)}.*{re.escape(cls._branch_pr_number_key_suffix)}$',
            ],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode not in (0, 1):
            return {}

        branch_numbers: dict[str, int] = {}
        for line in result.stdout.splitlines():
            key, _, value = line.partition(' ')
            if not key.startswith(cls._branch_cache_key_prefix):
                continue
            if not key.endswith(cls._branch_pr_number_key_suffix):
                continue
            branch = key[len(cls._branch_cache_key_prefix) : -len(cls._branch_pr_number_key_suffix)]
            if branch not in local_branches:
                continue
            try:
                branch_numbers[branch] = int(value.strip())
            except ValueError:
                continue

        if not branch_numbers:
            return {}

        result = subprocess.run(
            [
                'git',
                'config',
                '--local',
                '--get-regexp',
                rf'^{re.escape(cls._pr_cache_key_prefix)}[0-9]+\.',
            ],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode not in (0, 1):
            return {branch: cls.CachedPR(number=number) for branch, number in branch_numbers.items()}

        cached_by_number = {
            number: cls.CachedPR(number=number) for number in set(branch_numbers.values())
        }
        for line in result.stdout.splitlines():
            key, _, value = line.partition(' ')
            if not key.startswith(cls._pr_cache_key_prefix):
                continue
            remainder = key[len(cls._pr_cache_key_prefix) :]
            number_str, sep, field = remainder.partition('.')
            if not sep or field not in cls._pr_cache_fields:
                continue
            try:
                number = int(number_str)
            except ValueError:
                continue
            cached_pr = cached_by_number.get(number)
            if not cached_pr:
                continue
            match field:
                case 'url':
                    cached_pr.url = value.strip() or None
                case 'title':
                    cached_pr.title = value
                case 'state':
                    cached_pr.state = value.strip() or 'OPEN'
                case 'draft':
                    cached_pr.isDraft = value.strip().lower() in {'true', 'yes', 'on', '1'}
                case 'base':
                    cached_pr.baseRefName = value.strip() or None
                case 'oid':
                    cached_pr.headRefOid = value.strip() or None
                case _:
                    pass
        return {branch: cached_by_number[number] for branch, number in branch_numbers.items()}

    def update_pr_cache(
        self,
        branch_prs: dict[str, _Github.PR],
        local_branches: set[str],
        cached_prs: dict[str, _Github.CachedPR],
    ) -> dict[str, _Github.CachedPR]:
        actual_prs = {
            branch: _Github.CachedPR(
                number=pr['number'],
                url=pr['url'],
                isDraft=pr['isDraft'],
                state=pr['state'],
                baseRefName=pr['baseRefName'],
                headRefOid=pr['headRefOid'],
                title=pr['title'],
            )
            for branch, pr in branch_prs.items()
        }

        for branch, desired_pr in actual_prs.items():
            cached_pr = cached_prs.get(branch)
            if cached_pr and (
                cached_pr.number == desired_pr.number
                and cached_pr.url == desired_pr.url
                and cached_pr.isDraft == desired_pr.isDraft
                and cached_pr.state == desired_pr.state
                and cached_pr.baseRefName == desired_pr.baseRefName
                and cached_pr.headRefOid == desired_pr.headRefOid
                and cached_pr.title == desired_pr.title
            ):
                continue

            branch_key = f'{self._branch_cache_key_prefix}{branch}{self._branch_pr_number_key_suffix}'
            if (
                subprocess.run(
                    ['git', 'config', '--local', branch_key, str(desired_pr.number)],
                    capture_output=True,
                    text=True,
                    check=False,
                ).returncode
                != 0
            ):
                continue

            pr_key_prefix = f'{self._pr_cache_key_prefix}{desired_pr.number}.'
            writes = (
                ('url', desired_pr.url or ''),
                ('title', desired_pr.title),
                ('state', desired_pr.state),
                ('draft', 'true' if desired_pr.isDraft else 'false'),
                ('base', desired_pr.baseRefName or ''),
                ('oid', desired_pr.headRefOid or ''),
            )
            if all(
                subprocess.run(
                    ['git', 'config', '--local', f'{pr_key_prefix}{field}', value],
                    capture_output=True,
                    text=True,
                    check=False,
                ).returncode
                == 0
                for field, value in writes
            ):
                cached_prs[branch] = desired_pr
            else:
                cached_prs[branch] = _Github.CachedPR(number=desired_pr.number)

        for branch in sorted((set(cached_prs) & local_branches) - set(actual_prs)):
            _ = subprocess.run(
                [
                    'git',
                    'config',
                    '--local',
                    '--unset-all',
                    f'{self._branch_cache_key_prefix}{branch}{self._branch_pr_number_key_suffix}',
                ],
                capture_output=True,
                text=True,
                check=False,
            )
            _ = cached_prs.pop(branch, None)

        return cached_prs

@dataclass
class _CommitInfo:
    sha: str
    summary: str
    body: list[str]

    @cached_property
    def change_id(self) -> str | None:
        return _Gerrit.get_change_id(self.body)


@dataclass
class _BranchInfo:
    name: str
    branch_line: str
    upstream: str
    upstream_track: str
    pr_line: str | None = None
    cached_pr: _Github.CachedPR | None = None
    commits: list[_CommitInfo] = field(default_factory=list)
    gerrit_lines: dict[str, list[str]] = field(default_factory=dict)

    def render(
        self,
        show_gerrit_placeholders: bool = False,
        gerrit_base_url: str | None = None,
    ) -> list[str]:
        lines = [self.branch_line]
        if self.pr_line:
            lines.append(self.pr_line)
        for commit in self.commits:
            lines.append(f'  {_Ansi.GREY}·{_Ansi.END} {commit.summary}')
            if commit.sha in self.gerrit_lines:
                lines.extend(self.gerrit_lines[commit.sha])
            elif show_gerrit_placeholders and commit.change_id and gerrit_base_url:
                link = _link(
                    commit.change_id[:8],
                    f'{gerrit_base_url}/q/{commit.change_id}',
                )
                lines.append(
                    f'      {_Ansi.CYAN}{_Ansi.BOLD}gr{_Ansi.END} {link} {_Ansi.GREY}loading…{_Ansi.END}'
                )
        return lines


_BRANCH_FORMAT = (
    '%(HEAD)\t%(refname:short)\t%(upstream:short)\t%(upstream:track)\t%(committerdate:relative)'
)


def _format_upstream_track(track: str) -> str:
    if track.startswith('[') and track.endswith(']'):
        track = track[1:-1]
    return track.replace('ahead ', '↑').replace('behind ', '↓').replace(', ', '')


def _format_track_part(track: str) -> str:
    if not track:
        return ''
    parts: list[str] = []
    for direction, count in cast(list[tuple[str, str]], re.findall(r'([↑↓])(\d+)', track)):
        parts.append(f'{direction}{count}')
    rendered = ''.join(parts)
    if '↑' in rendered and '↓' in rendered:
        return f'{_Ansi.MAGENTA}{rendered}{_Ansi.END}'
    return rendered


def _format_branch_line(
    head: str,
    branch: str,
    upstream: str,
    upstream_track: str,
    date: str,
    worktree_dir: str | None,
    root: str | None,
    name_width: int,
) -> str:
    short_date = re.sub(r'(\d+\s+\w+)\s+ago', r'\1', date)
    head_marker = f'{_Ansi.BOLD}{_Ansi.GREEN}{_THIS}{_Ansi.END} ' if head == '*' else '  '
    if worktree_dir:
        branch_color = f'{_Ansi.BOLD}{_Ansi.CYAN}' if head == '*' else _Ansi.CYAN
    else:
        branch_color = f'{_Ansi.BOLD}{_Ansi.YELLOW}' if head == '*' else _Ansi.YELLOW
    branch_part = f'{branch_color}{branch.ljust(name_width)}{_Ansi.END}'
    extra_parts: list[str] = []
    if upstream and upstream != 'origin/main':
        extra_parts.append(f'{_Ansi.GREY}@{upstream}{_Ansi.END}')
    worktree_part = (
        f'{_Ansi.CYAN}wt:{relpath(Path(worktree_dir).resolve(), Path(root).resolve())}{_Ansi.END}'
        if worktree_dir and root
        else ''
    )
    if worktree_part:
        extra_parts.append(worktree_part)
    if track_part := _format_track_part(upstream_track):
        extra_parts.append(track_part)
    extra_parts.append(f'{_Ansi.GREY}{short_date}{_Ansi.END}')
    return head_marker + branch_part + '  ' + '  '.join(extra_parts)


def _get_branch_infos(worktree_dirs: dict[str, str]) -> list[_BranchInfo]:
    root = str(Path(_run('git rev-parse --git-common-dir')).parent) if worktree_dirs else None
    rows: list[tuple[str, str, str, str, str]] = []
    for line in _run(['git', 'branch', '--format', _BRANCH_FORMAT]).splitlines():
        head, branch, upstream, track, date = (line.split('\t') + [''] * 5)[:5]
        rows.append((head, branch, upstream, track, date))

    name_width = max((len(branch) for _, branch, _, _, _ in rows), default=0)

    branches: list[_BranchInfo] = []
    for head, branch, upstream, upstream_track_raw, date in rows:
        upstream_track = _format_upstream_track(upstream_track_raw)
        branches.append(
            _BranchInfo(
                name=branch,
                branch_line=_format_branch_line(
                    head,
                    branch,
                    upstream,
                    upstream_track,
                    date,
                    worktree_dirs.get(branch),
                    root,
                    name_width,
                ),
                upstream=upstream,
                upstream_track=upstream_track,
            )
        )
    return branches


def _get_default_compare_refs(remotes: list[str]) -> list[str]:
    refs: list[str] = []
    try:
        refs.extend(
            ref.strip()
            for ref in _run(
                ['git', 'for-each-ref', '--format=%(symref:short)', 'refs/remotes/*/HEAD']
            ).splitlines()
            if ref.strip()
        )
    except subprocess.CalledProcessError:
        pass

    for remote in remotes:
        refs.extend([f'{remote}/main', f'{remote}/master'])

    return list(dict.fromkeys(refs))

def _get_branch_commits_from_refs(
    branch: str,
    compare_refs: list[str],
    max_commits: int | None = None,
) -> list[_CommitInfo]:
    for compare_ref in dict.fromkeys(compare_refs):
        if not compare_ref:
            continue
        try:
            output = _run(
                [
                    'git',
                    '--no-pager',
                    'log',
                    '--format====%H%n%s%n%b',
                    f'{compare_ref}..refs/heads/{branch}',
                ]
            )
        except subprocess.CalledProcessError:
            continue
        commits: list[_CommitInfo] = []
        for commit in output.split('===')[1:]:
            lines = commit.strip().splitlines()
            if len(lines) < 2:
                continue
            sha, summary, *body = lines
            commits.append(_CommitInfo(sha=sha, summary=summary, body=body))
        if commits and (max_commits is None or len(commits) <= max_commits):
            return commits
    return []


def _get_branch_commits(
    branch: str,
    upstream: str,
    upstream_track: str,
    default_compare_refs: list[str],
    cached_compare_refs: list[str] | None = None,
) -> list[_CommitInfo]:
    if cached_compare_refs:
        commits = _get_branch_commits_from_refs(branch, cached_compare_refs, max_commits=32)
        if commits:
            return commits

    if not upstream or upstream_track == 'gone':
        return []

    commits = _get_branch_commits_from_refs(branch, [upstream])
    if commits:
        return commits

    _, _, upstream_branch = upstream.partition('/')
    if upstream_branch != branch:
        return []

    return _get_branch_commits_from_refs(branch, default_compare_refs, max_commits=32)

def _render_branches(
    branches: list[_BranchInfo],
    show_gerrit_placeholders: bool = False,
    gerrit_base_url: str | None = None,
) -> list[str]:
    lines: list[str] = []
    for branch in branches:
        lines.extend(
            branch.render(
                show_gerrit_placeholders=show_gerrit_placeholders,
                gerrit_base_url=gerrit_base_url,
            )
        )
    return lines


def _print_lines(lines: list[str]) -> None:
    if not lines:
        return
    _ = sys.stdout.write('\n'.join(lines) + '\n')
    _ = sys.stdout.flush()


def _replace_block(previous_line_count: int, lines: list[str]) -> None:
    if previous_line_count > 0:
        _ = sys.stdout.write(f'\033[{previous_line_count}A')
    _ = sys.stdout.write('\r\033[J')
    _print_lines(lines)


def _get_worktree_dirs() -> dict[str, str]:
    # Also handle git worktrees
    worktree_dirs: dict[str, str] = {}
    current_branch = None
    current_dir = None
    for line in _run(['git', 'worktree', 'list', '--porcelain']).splitlines():
        if line.startswith('worktree '):
            current_dir = line.split(' ', 1)[1]
        elif line.startswith('branch '):
            current_branch = line.split(' ', 1)[1]
            # Remove refs/heads/ prefix if present
            if current_branch.startswith('refs/heads/'):
                current_branch = current_branch[len('refs/heads/') :]
            if current_dir is not None:
                worktree_dirs[current_branch] = current_dir
                current_dir = None

    return worktree_dirs


def main():
    parser = argparse.ArgumentParser(description='Display Git branches with PR and Gerrit info')
    _ = parser.add_argument('--remote', action='store_true', help='Include remote branches')
    args = parser.parse_args()

    if bool(getattr(args, 'remote', False)):
        gerrit = _Gerrit.init()
        if gerrit:
            gerrit.info('owner:me is:open')
        return

    gerrit_base_url = _Gerrit.origin_base_url()
    try:
        remotes = [remote.strip() for remote in _run(['git', 'remote']).splitlines() if remote.strip()]
    except subprocess.CalledProcessError:
        remotes = []
    default_compare_refs = _get_default_compare_refs(remotes)
    worktree_dirs = _get_worktree_dirs()
    branches = _get_branch_infos(worktree_dirs)
    local_branch_names = {branch.name for branch in branches}
    cached_prs = _Github.cached_prs(local_branch_names)
    for branch in branches:
        branch.cached_pr = cached_prs.get(branch.name)

    interactive = sys.stdout.isatty()
    current_line_count = 0

    try:
        max_workers = min(16, max(4, len(branches) + 2))
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            github_future = executor.submit(_Github.init)
            gerrit_future = executor.submit(_Gerrit.init)
            branch_prs: dict[str, _Github.PR] = {}
            commit_futures: dict[str, Future[list[_CommitInfo]]] = {}
            for branch in branches:
                cached_compare_refs = (
                    list(dict.fromkeys(f'{remote}/{branch.cached_pr.baseRefName}' for remote in remotes))
                    if branch.cached_pr and branch.cached_pr.baseRefName
                    else []
                )
                commit_futures[branch.name] = executor.submit(
                    _get_branch_commits,
                    branch.name,
                    branch.upstream,
                    branch.upstream_track,
                    default_compare_refs,
                    cached_compare_refs,
                )

            for branch in branches:
                branch.commits.extend(commit_futures[branch.name].result())

            github = github_future.result() if github_future.done() else None
            if github:
                branch_prs = {
                    branch.name: pr
                    for branch in branches
                    if (pr := github.pr_for_branch(branch.name, branch.upstream))
                }
                for branch in branches:
                    pr = branch_prs.get(branch.name)
                    branch.pr_line = (
                        github.format_pr_line(
                            pr['number'],
                            pr['url'],
                            pr['isDraft'],
                            pr['state'],
                            pr['title'],
                        )
                        if pr
                        else None
                    )
                _ = executor.submit(github.update_pr_cache, branch_prs, local_branch_names, cached_prs)
            else:
                for branch in branches:
                    if not branch.cached_pr:
                        continue
                    if (
                        branch.cached_pr.number is not None
                        and branch.cached_pr.url
                        and branch.cached_pr.headRefOid
                        and branch.cached_pr.headRefOid in _branch_oids(branch.name, branch.upstream)
                    ):
                        branch.pr_line = _Github.format_pr_line(
                            branch.cached_pr.number,
                            branch.cached_pr.url,
                            branch.cached_pr.isDraft,
                            branch.cached_pr.state,
                            branch.cached_pr.title,
                        )
                    else:
                        branch.pr_line = (
                            f'  {_Ansi.CYAN}{_Ansi.BOLD}gh{_Ansi.END} {_Ansi.GREY}loading…{_Ansi.END}'
                        )

            if interactive:
                initial_lines = _render_branches(
                    branches,
                    show_gerrit_placeholders=True,
                    gerrit_base_url=gerrit_base_url,
                )
                _print_lines(initial_lines)
                current_line_count = len(initial_lines)

            if github is None:
                github = github_future.result()
                if github:
                    branch_prs = {
                        branch.name: pr
                        for branch in branches
                        if (pr := github.pr_for_branch(branch.name, branch.upstream))
                    }
                    for branch in branches:
                        pr = branch_prs.get(branch.name)
                        branch.pr_line = (
                            github.format_pr_line(
                                pr['number'],
                                pr['url'],
                                pr['isDraft'],
                                pr['state'],
                                pr['title'],
                            )
                            if pr
                            else None
                        )
                    _ = executor.submit(github.update_pr_cache, branch_prs, local_branch_names, cached_prs)

            pr_check_futures: dict[str, Future[_Github.CheckSummary | None]] = {}
            pr_comment_futures: dict[str, Future[int | None]] = {}
            pr_commit_futures: dict[str, Future[list[_CommitInfo]]] = {}
            if github:
                base_remote = github.base_remote
                for branch in branches:
                    pr = branch_prs.get(branch.name)
                    if not pr:
                        continue
                    pr_check_futures[branch.name] = executor.submit(github.get_pr_checks, pr['number'])
                    if pr['state'] == 'OPEN':
                        pr_comment_futures[branch.name] = executor.submit(
                            github.get_pr_unresolved_comments, pr['number']
                        )
                    compare_refs: list[str] = []
                    if base_remote:
                        compare_refs.append(f'{base_remote}/{pr["baseRefName"]}')
                    if branch.upstream and branch.upstream_track != 'gone':
                        compare_refs.append(branch.upstream)
                    pr_commit_futures[branch.name] = executor.submit(
                        _get_branch_commits_from_refs,
                        branch.name,
                        compare_refs,
                    )

            for branch in branches:
                future = pr_commit_futures.get(branch.name)
                if future is not None:
                    branch.commits = future.result()

            if interactive:
                commit_lines = _render_branches(
                    branches,
                    show_gerrit_placeholders=True,
                    gerrit_base_url=gerrit_base_url,
                )
                _replace_block(current_line_count, commit_lines)
                current_line_count = len(commit_lines)

            if github:
                for branch in branches:
                    pr = branch_prs.get(branch.name)
                    if not pr:
                        branch.pr_line = None
                        continue
                    check_summary = None
                    if future := pr_check_futures.get(branch.name):
                        check_summary = future.result()
                    unresolved_comments = None
                    if future := pr_comment_futures.get(branch.name):
                        unresolved_comments = future.result()
                    branch.pr_line = github.format_pr_line(
                        pr['number'],
                        pr['url'],
                        pr['isDraft'],
                        pr['state'],
                        pr['title'],
                        unresolved_comments,
                        check_summary,
                    )
            if interactive:
                pr_lines = _render_branches(
                    branches,
                    show_gerrit_placeholders=True,
                    gerrit_base_url=gerrit_base_url,
                )
                _replace_block(current_line_count, pr_lines)
                current_line_count = len(pr_lines)

            gerrit = gerrit_future.result()
            if gerrit:
                change_ids = [cid for b in branches for c in b.commits if (cid := c.change_id)]
                gerrit.prefetch_change_ids(change_ids)
                for branch in branches:
                    for commit in branch.commits:
                        if commit.sha not in branch.gerrit_lines and (changeid := commit.change_id):
                            branch.gerrit_lines[commit.sha] = gerrit.info_lines(changeid, commit.sha)
    finally:
        final_lines = _render_branches(branches)
        if interactive:
            _replace_block(current_line_count, final_lines)
        else:
            _print_lines(final_lines)


if __name__ == '__main__':
    main()
